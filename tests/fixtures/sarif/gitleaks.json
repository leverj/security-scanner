{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gitleaks",
          "version": "8.18.0",
          "informationUri": "https://github.com/gitleaks/gitleaks",
          "rules": [
            {
              "id": "generic-api-key",
              "name": "generic-api-key",
              "shortDescription": {
                "text": "Detected a generic API key, potentially exposing access to various services."
              }
            },
            {
              "id": "aws-access-token",
              "name": "aws-access-token",
              "shortDescription": {
                "text": "Identified a pattern that may indicate AWS credentials."
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "generic-api-key",
          "level": "error",
          "message": {
            "text": "generic-api-key has detected secret for file config/.env."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/.env"
                },
                "region": {
                  "startLine": 4,
                  "snippet": {
                    "text": "sk_live_FAKE_9f8e7d6c5b4a3210ZZZZ"
                  }
                }
              }
            }
          ],
          "partialFingerprints": {
            "commitSha": "deadbeefcafef00d1234567890abcdef12345678",
            "secretHash": "9b1e2c3d4f5a6b7c8d9e0f1a2b3c4d5e"
          }
        },
        {
          "ruleId": "aws-access-token",
          "level": "error",
          "message": {
            "text": "aws-access-token has detected secret for file infra/deploy.sh."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "infra/deploy.sh"
                },
                "region": {
                  "startLine": 12,
                  "snippet": {
                    "text": "TEST_FAKE_AWS_KEY_PLACEHOLDER"
                  }
                }
              }
            }
          ],
          "partialFingerprints": {
            "commitSha": "1234567890abcdef1234567890abcdef12345678",
            "secretHash": "aaa111bbb222ccc333ddd444eee555fff666"
          }
        }
      ]
    }
  ]
}
