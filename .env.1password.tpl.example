# 1Password env-file template for secscan.
#
# Copy this file to `.env.1password.tpl` (which is gitignored) and edit the
# `op://vault/item/field` paths to point at your own 1Password vault entries:
#
#   cp .env.1password.tpl.example .env.1password.tpl
#   $EDITOR .env.1password.tpl
#
# Then in config.yaml set:
#   secrets:
#     source: "1password"
#     env_file: ".env.1password.tpl"
#
# `./secscan.sh run` will auto-wrap with `op run --env-file=...`.
#
# The op:// references are NOT secret values — they're paths into your vault.
# 1Password CLI (`brew install 1password-cli`) is required, and you must be
# signed in (`op signin`).

GITHUB_TOKEN=op://<vault>/<item>/GITHUB_TOKEN
SLACK_WEBHOOK_URL=op://<vault>/<item>/SLACK_WEBHOOK_URL

# Optional — only needed if config.yaml uses chat.postMessage instead of webhook:
# SLACK_BOT_TOKEN=op://<vault>/<item>/SLACK_BOT_TOKEN
# SLACK_CHANNEL_ID=op://<vault>/<item>/SLACK_CHANNEL_ID
